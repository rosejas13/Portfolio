# Development: connects to local Docker stack (Caddy → PostgREST → PostgreSQL)
# Leave API_URL empty to use the default http://localhost:3001

# Local JWT secret (must match docker-compose.yml PGRST_JWT_SECRET)
JWT_SECRET=dev-secret-change-in-production-this-is-32-chars!!

# Supabase is not used in local dev — the Docker stack provides everything
