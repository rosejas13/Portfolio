# Environment variables for the Next.js frontend.
# Copy the appropriate file:
#   cp .env.development .env.local    (for local dev)
#   (for production, set these in Vercel/Supabase dashboards)
#
# Files are committed; .env.local is gitignored.

# ---- Local development (Docker stack) ----
# API_URL is NOT needed locally — Next.js rewrites default to http://localhost:3001
# JWT_SECRET must match docker-compose.yml PGRST_JWT_SECRET

# ---- Production (Vercel + Supabase) ----
# API_URL=https://<your-project>.supabase.co/rest/v1
# NODE_ENV=production
# (JWT is managed by Supabase Auth — no secret needed)
# NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Slack webhook for contact form notifications (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=
