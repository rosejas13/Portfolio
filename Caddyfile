# Development (HTTP on localhost)
http://localhost:3001 {
  import security-headers
  reverse_proxy postgrest:3000 {
    header_up X-Forwarded-For {remote_host}
    header_up X-Real-IP {remote_host}
  }
}

# Production (automatic TLS via Let's Encrypt)
# Uncomment and replace with your domain:
# https://api.jcrose.dev {
#   import security-headers
#   reverse_proxy postgrest:3000 {
#     header_up X-Forwarded-For {remote_host}
#     header_up X-Real-IP {remote_host}
#   }
# }

(security-headers) {
  log {
    output file /var/log/caddy/api.log
    format json
  }

  # Rate limiting: 60 requests per minute per client IP to /rpc/login_dev
  @login_dev {
    path /rpc/login_dev
  }
  rate_limit @login_dev 10/m

  # Rate limiting: 5 POSTs per minute to /leads (contact form)
  @leads_post {
    path /leads
    method POST
  }
  rate_limit @leads_post 5/m

  # General rate limit: 100 requests per minute
  rate_limit 100/m

  # Allow only specific origins for CORS
  @allowed_origin {
    # Development origins
    header Origin http://localhost:5173
  }
  @allowed_origin_prod {
    # Production origins (add your domain)
    header Origin https://jcrose.dev
  }

  @cors_preflight {
    method OPTIONS
    header Origin *
  }

  handle @cors_preflight {
    header {
      Access-Control-Allow-Origin "http://localhost:5173"
      Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
      Access-Control-Allow-Headers "Authorization, Content-Type, Prefer, X-Requested-With, X-CSRF-Token"
      Access-Control-Allow-Credentials "true"
      Access-Control-Max-Age 86400
    }
    respond 204
  }

  handle {
    header {
      Access-Control-Allow-Origin "http://localhost:5173"
      Access-Control-Expose-Headers "Content-Range, Content-Location, X-RateLimit-Limit, X-RateLimit-Remaining, X-RateLimit-Reset"
      Access-Control-Allow-Credentials "true"
      Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
      X-Content-Type-Options "nosniff"
      X-Frame-Options "DENY"
      Referrer-Policy "strict-origin-when-cross-origin"
      X-XSS-Protection "0"
      Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
      Content-Security-Policy "default-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; script-src 'self'; connect-src 'self'"
      -Server
    }

    # TLS 1.2+ only, strong ciphers, HTTP/2
    # Caddy handles this automatically when using https://
  }
}
