{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug Frontend",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*",
        "/@id/*": "${workspaceFolder}/*",
        "/__vite/*": "${workspaceFolder}/*"
      },
      "preLaunchTask": "Start Vite Dev Server"
    }
  ]
}
